        "@types/eslint": "^9.6.0",
        "autoprefixer": "^10.4.19",
        "eslint": "^9.8.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-svelte": "^2.43.0",
        "globals": "^15.8.0",
        "postcss": "^8.4.40",
        "prettier": "^3.3.3",
        "prettier-plugin-svelte": "^3.2.6",
        "svelte": "5.0.0-next.205",
        "svelte-check": "^3.8.5",
        "tailwindcss": "^3.4.7",
        "tslib": "^2.4.1",
        "typescript": "^5.5.4",
        "typescript-eslint": "^8.0.0",
        "vite": "^5.3.5",
